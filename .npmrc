# NPM Registry Configuration for @readmigo-cn/napi-bridge
#
# @readmigo-cn scoped packages are published to Huawei Cloud CodeArts
# Artifact (private npm registry). Public npm.org is NOT used for this scope.
#
# See MIRROR_POLICY.md for the overall mirror / publish strategy.

# Default registry for non-scoped deps (build tooling, etc.)
registry=https://registry.npmjs.org/

# @readmigo-cn scoped packages → Huawei Cloud CodeArts Artifact
@readmigo-cn:registry=https://repo-codearts.cn-north-4.myhuaweicloud.com/repository/npm/

# Auth token for the CodeArts registry.
# In CI, publish.yml writes this line dynamically using:
#   ${{ secrets.HUAWEI_CODEARTS_TOKEN }}
# For local publish:
#   npm config set //repo-codearts.cn-north-4.myhuaweicloud.com/repository/npm/:_authToken <token>
# Do NOT commit a real token here.
//repo-codearts.cn-north-4.myhuaweicloud.com/repository/npm/:_authToken=${HUAWEI_CODEARTS_TOKEN}

strict-ssl=true
fetch-timeout=60000
